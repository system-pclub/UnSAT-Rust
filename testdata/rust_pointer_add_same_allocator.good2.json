{
  "rule": "rust.pointer_add.same_allocator",
  "description": "Equivalent formulation: violation when same-allocator relation is false.",
  "function": {
    "name": "ptr_add",
    "arguments": [
      {"name": "src_alloc", "sort": "Int"},
      {"name": "dst_alloc", "sort": "Int"}
    ]
  },
  "abstracts": [
    {
      "name": "same_allocator",
      "parameters": [
        {"name": "src_alloc", "sort": "Int"},
        {"name": "dst_alloc", "sort": "Int"}
      ],
      "returns": {"sort": "Int"}
    }
  ],
  "variables": [
    {
      "name": "same_allocator_flag",
      "sort": "Int",
      "selector": {
        "apply": "same_allocator",
        "args": [
          {"argument": "src_alloc"},
          {"argument": "dst_alloc"}
        ]
      }
    }
  ],
  "buggy_violation": {
    "op": "not",
    "args": [
      {
        "op": "!=",
        "args": [
          {"var": "same_allocator_flag"},
          {"int": 0}
        ]
      }
    ]
  }
}
