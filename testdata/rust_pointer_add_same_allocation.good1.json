{
  "rule": "rust.pointer_add.same_allocation",
  "description": "Result pointer and source pointer must originate from the same allocation.",
  "function": {
    "name": "ptr_add",
    "arguments": [
      {"name": "src", "sort": "Int"},
      {"name": "result", "sort": "Int"}
    ]
  },
  "abstracts": [
    {
      "name": "same_alloc",
      "parameters": [
        {"name": "src", "sort": "Int"},
        {"name": "result", "sort": "Int"}
      ],
      "returns": {"sort": "Int"}
    }
  ],
  "variables": [
    {
      "name": "same_alloc_flag",
      "sort": "Int",
      "selector": {
        "apply": "same_alloc",
        "args": [
          {"argument": "src"},
          {"argument": "result"}
        ]
      }
    }
  ],
  "buggy_violation": {
    "op": "=",
    "args": [
      {"var": "same_alloc_flag"},
      {"int": 0}
    ]
  }
}
