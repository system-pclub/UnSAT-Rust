[package]
name = "aragonite"
version = "0.1.0"
edition = "2021"
description = "a library for producing position-independent shellcode on win/linux targets"
readme = "./README.md"
repository = "https://www.gitlab.com/aragonite-rs/aragonite"
license = "MIT OR Apache-2.0"
keywords = [ "shellcode", "pic", "windows", "linux", "security" ]
categories = [ "development-tools", "no-std", "os::linux", "os::windows-apis" ]

# See more keys and their definitions at https://doc.rust-lang.org/cargo/reference/manifest.html

[dependencies]
aragonite_macros.workspace = true

[dependencies.windows-sys]
version = "0.52.0"
features = [
  "Win32_Foundation",
  "Win32_Security",
  "Win32_System_Threading",
  "Win32_UI_WindowsAndMessaging",
  "Win32_System_LibraryLoader",
  "Win32_System_Kernel",
  "Win32_System_WindowsProgramming",
  "Win32_System_SystemServices",
  "Win32_System_Diagnostics_Debug",
  "Win32_System_SystemInformation",
]
